BoxLayout:
    orientation: "vertical"
    padding: 10
    spacing: 10

    Label:
        id: top_status_label
        text: "Places to visit: 0"
        size_hint_y: None
        height: "40dp"
        bold: True

    BoxLayout:
        spacing: 10

        BoxLayout:
            orientation: "vertical"
            size_hint_x: 0.3
            spacing: 10

            Spinner:
                id: sort_spinner
                text: "Sort by"
                values: ("Name", "Country", "Priority", "Visited")
                size_hint_y: None
                height: "40dp"
                on_text: app.sort_places(self.text)

            Label:
                text: "Add New Place..."
                size_hint_y: None
                height: "40dp"

            Label:
                text: "Name:"
                size_hint_y: None
                height: "30dp"

            TextInput:
                id: name_input
                multiline: False
                write_tab: False
                size_hint_y: None
                height: "40dp"
                on_text_validate: country_input.focus = True

            Label:
                text: "Country:"
                size_hint_y: None
                height: "30dp"

            TextInput:
                id: country_input
                multiline: False
                write_tab: False
                size_hint_y: None
                height: "40dp"
                on_text_validate: priority_input.focus = True

            Label:
                text: "Priority:"
                size_hint_y: None
                height: "30dp"

            TextInput:
                id: priority_input
                multiline: False
                write_tab: False
                input_filter: "int"
                size_hint_y: None
                height: "40dp"
                on_text_validate: app.add_place()

            Button:
                text: "Add Place"
                size_hint_y: None
                height: "45dp"
                on_release: app.add_place()

            Button:
                text: "Clear"
                size_hint_y: None
                height: "45dp"
                on_release: app.clear_fields()

            Widget:

        ScrollView:
            size_hint_x: 0.7

            GridLayout:
                id: places_box
                cols: 1
                size_hint_y: None
                height: self.minimum_height
                spacing: 10

    Label:
        id: bottom_status_label
        text: ""
        size_hint_y: None
        height: "40dp"